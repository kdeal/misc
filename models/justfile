stl scad_file:
    #!/bin/sh
    set -eu
    scad_file="{{scad_file}}"
    output_file="${scad_file%.scad}.stl"
    docker run --rm \
      -v "{{invocation_directory()}}:/openscad" \
      -w /openscad \
      -u "$(id -u):$(id -g)" \
      openscad/openscad:trixie \
      openscad -o "$output_file" "$scad_file"

all-stl:
    #!/bin/sh
    set -eu
    for file in "{{invocation_directory()}}"/*.scad; do
      echo "Generating stl for $file"
      just stl "$(basename "$file")"
    done

check-stl:
    #!/bin/sh
    set -eu
    missing=0
    for file in "{{invocation_directory()}}"/*.scad; do
      stl_file="${file%.scad}.stl"
      if [ ! -f "$stl_file" ]; then
        echo "Missing STL for $(basename "$file")"
        missing=1
      fi
    done
    if [ "$missing" -ne 0 ]; then
      exit 1
    fi
    echo "All SCAD files have matching STL files"
